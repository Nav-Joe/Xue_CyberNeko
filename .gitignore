voice_forge/other_custom_cache/**/*
!voice_forge/other_custom_cache/README.md
voice_forge/**/touch_cache/
voice_forge/**/touch_cache.json
voice_forge/**/corpus.snapshot.json
voice_forge/custom_sample/**/*
!voice_forge/custom_sample/README.md

# ── 本地 TTS / 触摸模式覆盖 ──
.runtime/tts-backend.env
.runtime/touch-mode.env
.runtime/corpus.custom.json
切换TTS引擎.bat

